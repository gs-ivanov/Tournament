@page
@using Tournament.Areas.Identity.Pages.Account
@model ConfirmManagerRequestModel
@{
    ViewData["Title"] = "Потвърди участие";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center mb-0 rounded-0">
        @TempData["Error"]
    </div>
}

<h2 class="mt-4">Потвърдете участието си като мениджър</h2>

<form method="post" class="mt-3">
    <div class="form-group">
        <label asp-for="ConfirmationCode"></label>
        <input asp-for="ConfirmationCode" class="form-control" placeholder="Код от SMS (User ID)" value="levski08041718@sof.com" />
        <span asp-validation-for="ConfirmationCode" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" placeholder="Имейл адрес" value="levski08041718@sof.com" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ReceiptNumber"></label>
        <input asp-for="ReceiptNumber" class="form-control" placeholder="Номер на разписка" value="9999" />
        <span asp-validation-for="ReceiptNumber" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-3">Потвърди</button><br/>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
