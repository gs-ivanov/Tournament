@page

@model RegisterModel
@using Tournament.Models
@{ ViewData["Title"] = "Register"; }

<div class="row">
    <div class="col-md-4 offset-md-4">
        <h2 class="text-center">@ViewData["Title"]</h2>

        <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.FullName"></label>
                <input asp-for="Input.FullName" class="form-control" />
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" class="form-control" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Input.BecomeManager" class="form-check-input" id="managerCheck" />
                <label asp-for="Input.BecomeManager" class="form-check-label"></label>
            </div>

            <div class="form-group mb-3 manager-only" style="display: none;">
                <label asp-for="Input.TournamentType" class="form-label"></label>
                <select asp-for="Input.TournamentType" asp-items="Html.GetEnumSelectList<TournamentType>()" class="form-control"></select>
                <span asp-validation-for="Input.TournamentType" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const checkbox = document.getElementById("managerCheck");
        const managerFields = document.querySelectorAll(".manager-only");

        function toggleManagerFields() {
            managerFields.forEach(el => {
                el.style.display = checkbox.checked ? "block" : "none";
            });
        }

        checkbox.addEventListener("change", toggleManagerFields);
        window.addEventListener("load", toggleManagerFields);
    </script>
}
}
