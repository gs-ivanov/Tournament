@model IEnumerable<Tournament>

@{
    ViewData["Title"] = "Турнири";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-info">@TempData["Error"]</div>
}

<h2 class="mt-3">Списък с турнири</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Име</th>
            <th>Тип</th>
            <th>Начална дата</th>
            <th>Отворен за заявки</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tournament in Model)
        {
            var isDeletable = !tournament.Matches.Any();

            <tr>
                <td>@tournament.Name</td>
                <td>@tournament.Type</td>
                <td>@tournament.StartDate.ToShortDateString()</td>
                <td>
                    @(tournament.IsOpenForApplications ? "✅ Да" : "❌ Не")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@tournament.Id" class="btn btn-warning btn-sm">Редактирай Fault</a>

                    @if (isDeletable)  // If matches not exists you can delete
                    {
                        <form asp-action="Delete" asp-route-id="@tournament.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm">Изтрий</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">🔒 Има мачове</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-success">➕ Създай нов турнир</a>
