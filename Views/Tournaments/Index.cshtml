@using Tournament.Data.Models
@model IEnumerable<Match>

@{
    ViewData["Title"] = "Списък с мачове";
}

<h2>Списък с мачове</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Име</th>
            <th>Тип</th>
            <th>Начална дата</th>
            <th>Активен</th>
            <th>Отворен за заявки</th> <!-- 🆕 -->
            <th>Действие</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var match in Model)
        {
            <tr>
                <td>@match.Tournament?.Name</td>
                <td>@match.TeamA?.Name</td>
                <td>@match.TeamB?.Name</td>
                <td>@match.PlayedOn.ToString()</td>
                <td>@match.ScoreA : @match.ScoreB</td>
                <td>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@match.Id">Редактирай резултат</a>
                </td>
            </tr>
        }
    </tbody>
</table>
