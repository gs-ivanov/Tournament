@model IEnumerable<Match>

@using static Tournament.WebConstants

<h2>График на мачовете</h2>

<h5 class="text-black-10 text-center table-warning"> @TempData[GlobalMessageKey]</h5>

<table>
    <thead>
        <tr>
            <th class="text-md-center">Дата</th>
            <th class="text-md-center">Домакин</th>
            <th class="text-md-center">Резултат</th>
            <th class="text-md-center">Гост</th>
            <th class="text-md-center">Действие</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var match in Model)
        {
            <tr>
                <td>@match.PlayedOn.ToString()</td>
                <td>@match.TeamA.Name</td>
                <td class="text-md-center">@match.ScoreA : @match.ScoreB</td>
                <td>@match.TeamB.Name</td>
                <td>
                    @if (User.IsInRole("Editor"))
                    {
                        <a asp-action="Edit" asp-route-id="@match.Id" class="btn btn-warning btn-sm">Редактирай</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>