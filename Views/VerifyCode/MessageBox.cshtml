@model MessageBoxViewModel

@{
    ViewData["Title"] = Model.Title;
    string alertClass = Model.Type switch
    {
        "success" => "alert-success",
        "error" => "alert-danger",
        "warning" => "alert-warning",
        _ => "alert-info"
    };
}

<div class="container mt-5">
    <div class="alert @alertClass" role="alert">
        <h4 class="alert-heading">@Model.Title</h4>
        <p>@Model.Message</p>
        <hr />
        <a href="javascript:history.back()" class="btn btn-outline-dark">⬅ Назад</a>
    </div>
</div>
